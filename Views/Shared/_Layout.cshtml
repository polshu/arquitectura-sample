<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Indeura</title>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; max-width: 860px; margin: 2rem auto; padding: 0 1.2rem; color: #222; line-height: 1.55; }
        h1 { border-bottom: 2px solid #333; padding-bottom: .3rem; }
        h2 { margin-top: 2.2rem; }
        code { background: #f1f1f1; padding: 0.15rem 0.4rem; border-radius: 3px; font-size: 0.95em; }
        pre { background: #f1f1f1; padding: 0.9rem 1.1rem; border-radius: 4px; overflow-x: auto; line-height: 1.4; }
        .endpoint { border: 1px solid #ddd; border-radius: 6px; padding: 0.9rem 1.2rem; margin: 1rem 0; background: #fafafa; }
        .endpoint h3 { margin-top: 0; font-family: ui-monospace, Menlo, Consolas, monospace; font-size: 1.0rem; }
        .verb-get { color: #2a7f2a; font-weight: 700; }
        .verb-post { color: #b35900; font-weight: 700; }
        a.btn { display: inline-block; background: #333; color: #fff; padding: 0.35rem 0.9rem; border-radius: 4px; text-decoration: none; font-size: 0.9rem; margin-top: 0.4rem; }
        a.btn:hover { background: #555; }
        footer { margin-top: 3rem; color: #666; font-size: 0.9rem; border-top: 1px solid #eee; padding-top: 1rem; }
    </style>
</head>
<body>
    @RenderBody()
    <footer>
        Proyecto educativo — arquitectura por capas: Controller &rarr; Service &rarr; Repository &rarr; DB.
    </footer>
</body>
</html>
