@model proyect.DTOs.Input.GameUpdateDto

@{
    ViewData["Title"] = "Editar juego";
    int gameId = (int)ViewBag.GameId;
    string? errorMessage = ViewBag.ErrorMessage as string;
}

@*
    Formulario de edicion. La vista recibe un GameUpdateDto pre-cargado con
    los valores actuales del juego (lo arma el Controller en EditForm), y el
    Id por ViewBag (el DTO no incluye Id porque va por URL).

    A diferencia del Create, este SI permite cambiar State y DiscountPercentage,
    que son cosas que el publisher puede modificar despues del alta (publicar,
    aplicar descuentos, etc.).
*@

<style>
    form.card { background: #fafafa; border: 1px solid #ddd; border-radius: 6px; padding: 1rem 1.2rem; margin-top: 0.8rem; }
    form.card label { display: block; margin-top: 0.7rem; font-weight: 600; font-size: 0.95rem; }
    form.card input, form.card textarea, form.card select { width: 100%; padding: 0.4rem 0.6rem; font-size: 0.95rem; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; background: #fff; }
    form.card textarea { min-height: 70px; resize: vertical; }
    form.card .actions { margin-top: 1rem; display: flex; gap: 0.5rem; }
    form.card button { background: #b35900; color: #fff; border: 0; padding: 0.5rem 1.2rem; border-radius: 4px; cursor: pointer; font-size: 0.95rem; }
    form.card button:hover { background: #d06d00; }
    a.btn.secondary { background: #555; }
    .error { background: #fbe6e6; border: 1px solid #e0b0b0; color: #7a2a2a; padding: 0.6rem 0.9rem; border-radius: 4px; margin-top: 0.8rem; }
</style>

<h1>Editar juego #@gameId</h1>

<p>
    <a href="/games/details/@gameId">&larr; Volver al detalle</a> |
    <a href="/games">Ir a la lista</a>
</p>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error">@errorMessage</div>
}

<form class="card" method="post" action="/games/edit/@gameId">
    <label for="GameName">Nombre</label>
    <input type="text" id="GameName" name="GameName" required maxlength="200" value="@Model.GameName" />

    <label for="Description">Descripcion</label>
    <textarea id="Description" name="Description">@Model.Description</textarea>

    <label for="Date">Fecha de publicacion</label>
    <input type="datetime-local" id="Date" name="Date"
           value="@Model.Date.ToString("yyyy-MM-ddTHH:mm")" />

    <label for="NumberOfAchievements">Cantidad de logros</label>
    <input type="number" id="NumberOfAchievements" name="NumberOfAchievements" min="0"
           value="@Model.NumberOfAchievements" />

    <label for="PriceUSD">Precio USD</label>
    <input type="number" id="PriceUSD" name="PriceUSD" step="0.01" min="0"
           value="@Model.PriceUSD.ToString("0.00")" />

    <label for="DiscountPercentage">Descuento %</label>
    <input type="number" id="DiscountPercentage" name="DiscountPercentage" step="0.01" min="0" max="100"
           value="@Model.DiscountPercentage.ToString("0.##")" />

    <label for="State">Estado</label>
    <select id="State" name="State">
        <option value="Private" selected="@(Model.State == "Private")">Private</option>
        <option value="Public" selected="@(Model.State == "Public")">Public</option>
    </select>

    <div class="actions">
        <button type="submit">Guardar cambios</button>
        <a class="btn secondary" href="/games/details/@gameId">Cancelar</a>
    </div>
</form>
