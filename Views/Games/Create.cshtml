@model proyect.DTOs.Input.GameCreateDto

@{
    ViewData["Title"] = "Crear juego";
    string? errorMessage = ViewBag.ErrorMessage as string;
}

@*
    Formulario de alta. Postea a /games/create con Content-Type
    application/x-www-form-urlencoded (un <form> HTML normal).
    El Controller lo bindea con [FromForm] GameCreateDto.

    Si falla una validacion, el Controller vuelve a renderizar esta misma
    vista con el DTO ya completado y el mensaje de error en ViewBag.
*@

<style>
    form.card { background: #fafafa; border: 1px solid #ddd; border-radius: 6px; padding: 1rem 1.2rem; margin-top: 0.8rem; }
    form.card label { display: block; margin-top: 0.7rem; font-weight: 600; font-size: 0.95rem; }
    form.card input, form.card textarea { width: 100%; padding: 0.4rem 0.6rem; font-size: 0.95rem; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
    form.card textarea { min-height: 70px; resize: vertical; }
    form.card .actions { margin-top: 1rem; display: flex; gap: 0.5rem; }
    form.card button { background: #2a7f2a; color: #fff; border: 0; padding: 0.5rem 1.2rem; border-radius: 4px; cursor: pointer; font-size: 0.95rem; }
    form.card button:hover { background: #3a9f3a; }
    a.btn.secondary { background: #555; }
    .error { background: #fbe6e6; border: 1px solid #e0b0b0; color: #7a2a2a; padding: 0.6rem 0.9rem; border-radius: 4px; margin-top: 0.8rem; }
</style>

<h1>Crear juego nuevo</h1>

<p>
    <a href="/games">&larr; Volver a la lista</a>
</p>

<p>
    Los campos que ves aca son los que define <code>GameCreateDto</code>.
    El <code>Id</code>, la <code>Date</code>, el <code>State</code> (arranca
    en <code>Private</code>) y el <code>DiscountPercentage</code> los setea
    el servidor, no el cliente.
</p>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="error">@errorMessage</div>
}

<form class="card" method="post" action="/games/create">
    <label for="GameName">Nombre del juego</label>
    <input type="text" id="GameName" name="GameName" required maxlength="200" value="@Model.GameName" />

    <label for="Description">Descripcion</label>
    <textarea id="Description" name="Description">@Model.Description</textarea>

    <label for="IdPublisher">Id del publisher (User existente)</label>
    <input type="number" id="IdPublisher" name="IdPublisher" required min="1"
           value="@(Model.IdPublisher == 0 ? 1 : Model.IdPublisher)" />

    <label for="PriceUSD">Precio en USD</label>
    <input type="number" id="PriceUSD" name="PriceUSD" step="0.01" min="0"
           value="@Model.PriceUSD.ToString("0.00")" />

    <label for="NumberOfAchievements">Cantidad de logros</label>
    <input type="number" id="NumberOfAchievements" name="NumberOfAchievements" min="0"
           value="@Model.NumberOfAchievements" />

    <div class="actions">
        <button type="submit">Crear</button>
        <a class="btn secondary" href="/games">Cancelar</a>
    </div>
</form>
